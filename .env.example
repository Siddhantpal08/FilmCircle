# Server environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb+srv://samarthgupta:Samarthgupta09@cluster0.vo2mv9l.mongodb.net/filmcircle
# OR MongoDB Atlas free tier (replace with your connection string):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/filmcircle?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Use a long, random string — NEVER share this
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── OMDb API (IMDB movie data) ───────────────────────────────────────────────
# Get your free key at: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here
OMDB_BASE_URL=https://www.omdbapi.com/

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend development URL
CLIENT_URL=http://localhost:5173
# Production (update after deploying to Vercel):
# CLIENT_URL=https://filmcircle.vercel.app
